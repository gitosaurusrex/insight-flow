# === Database ===
# Option 1: Full connection string (used by Render)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Option 2: Individual vars (used by docker-compose)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=insightflow
POSTGRES_PASSWORD=insightflow
POSTGRES_DB=insightflow

# === MongoDB ===
# Full connection string (use MongoDB Atlas for Render deployment)
# MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=insightflow

# === Redis ===
# Full connection string (provided by Render)
# REDIS_URL=redis://host:6379
REDIS_HOST=redis
REDIS_PORT=6379

# === JWT ===
SECRET_KEY=change-me-to-a-secure-random-string

# === Celery ===
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === CORS ===
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
